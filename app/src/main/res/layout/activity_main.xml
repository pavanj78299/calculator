<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="8dp">

    <!-- Preview -->
    <TextView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:padding="12dp"
        android:text=""
        android:textColor="#888888"
        android:textSize="24sp" />

    <!-- Result -->
    <TextView
        android:id="@+id/result"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:padding="12dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold" />

    <!-- Buttons -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:rowCount="5"
        android:useDefaultMargins="true">

        <!-- Row 1 -->
        <Button
            android:text="AC"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="⌫"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="%"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="÷"
            android:onClick="onClick"
            style="@style/btnOrange"/>

        <!-- Row 2 -->
        <Button
            android:text="7"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="8"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="9"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="×"
            android:onClick="onClick"
            style="@style/btnOrange"/>

        <!-- Row 3 -->
        <Button
            android:text="4"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="5"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="6"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="-"
            android:onClick="onClick"
            style="@style/btnOrange"/>

        <!-- Row 4 -->
        <Button
            android:text="1"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="2"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="3"
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="+"
            android:onClick="onClick"
            style="@style/btnOrange"/>

        <!-- Row 5 -->
        <Button
            android:text="0"
            android:onClick="onClick"
            android:layout_columnSpan="2"
            style="@style/btnZero"/>

        <Button
            android:text="."
            android:onClick="onClick"
            style="@style/btnDark"/>

        <Button
            android:text="="
            android:onClick="onClick"
            style="@style/btnOrange"/>

    </GridLayout>

</LinearLayout>