<resources>

    <style name="Theme.Calculator" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <style name="btnDark">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/btn_ripple</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="btnOrange">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/btn_orange</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="btnZero">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_columnWeight">2</item>
        <item name="android:background">@drawable/btn_ripple</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
